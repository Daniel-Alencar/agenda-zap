# =============================================
# VARIÁVEIS DE AMBIENTE — AgendaZap
# =============================================
# Copie este arquivo para .env.local e preencha com seus valores.
# NUNCA commite o .env.local no repositório.

# =============================================
# SUPABASE
# =============================================
# Encontre em: https://supabase.com/dashboard → seu projeto → Settings → API

# URL pública do projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Chave anônima pública (safe para expor no frontend)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================
# BANCO DE DADOS (Prisma)
# =============================================
# Encontre em: Supabase → Settings → Database → Connection string → URI
# Use o "Transaction pooler" (porta 6543) para ambientes serverless (Vercel)
# Use o "Session pooler" ou conexão direta (porta 5432) para desenvolvimento local

DATABASE_URL=postgresql://postgres.xxxx:senha@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# =============================================
# EVOLUTION API (WhatsApp)
# =============================================
# URL do servidor onde a Evolution API está rodando

EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua-chave-secreta-aqui

# =============================================
# APP
# =============================================
# URL base da aplicação (sem barra no final)
# Em produção: https://seudominio.com.br
# Em desenvolvimento: http://localhost:3000

NEXT_PUBLIC_APP_URL=http://localhost:3000
