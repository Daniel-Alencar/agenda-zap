generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  // UUID do Supabase Auth
  id        String   @id 
  email     String   @unique
  // Mantido por compatibilidade — Supabase gerencia a senha
  password  String   
  name      String
  username  String   @unique
  phone     String?

  evolutionInstanceName String?
  evolutionConnected    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services     Service[]
  appointments Appointment[]
  customers    Customer[]
  businessHours BusinessHours[]
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  duration    Int
  active      Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  appointments Appointment[]

  @@index([userId])
}

model Customer {
  id    String  @id @default(cuid())
  name  String
  phone String  // Formato: 5511999999999
  email String?

  // Estado da conversa no WhatsApp para fluxo stateful
  // null | "AWAITING_BOOKING" | "AWAITING_CANCEL_CONFIRM"
  conversationState String?
  lastMessageAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  appointments Appointment[]

  @@unique([phone, userId])
  @@index([userId])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Appointment {
  id        String            @id @default(cuid())
  date      DateTime
  startTime DateTime
  endTime   DateTime
  status    AppointmentStatus @default(PENDING)
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  serviceId  String
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@index([status])
}

// =============================================
// MODEL: BUSINESS HOURS (Horários de Funcionamento)
// =============================================
// Define os horários de atendimento por dia da semana.
// dayOfWeek: 0 = domingo, 1 = segunda, ..., 6 = sábado
// Dias sem registro = fechado.
// slotInterval: intervalo em minutos entre slots (ex: 30 = slots de meia em meia hora)

model BusinessHours {
  id           String  @id @default(cuid())
  dayOfWeek    Int     // 0–6
  openTime     String  // "HH:MM" ex: "09:00"
  closeTime    String  // "HH:MM" ex: "18:00"
  slotInterval Int     @default(30) // minutos entre slots

  // Intervalo de almoço (opcional)
  lunchStart   String? // "HH:MM" — null = sem intervalo
  lunchEnd     String? // "HH:MM"

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayOfWeek])
  @@index([userId])
}
